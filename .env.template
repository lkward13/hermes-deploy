# Hermes Agent — Per-Client Environment
# Copy to .env and fill in all values before starting the agent.

# --- Hermes Runtime ---
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false
HERMES_MAX_ITERATIONS=90

# --- Telegram ---
TELEGRAM_BOT_TOKEN="{{TELEGRAM_BOT_TOKEN}}"
TELEGRAM_BOT_USERNAME="{{TELEGRAM_BOT_USERNAME}}"
TELEGRAM_HOME_CHANNEL="{{TELEGRAM_OWNER_CHAT_ID}}"
WEBHOOK_ENABLED=true
TELEGRAM_ALLOWED_USERS="{{TELEGRAM_ALLOWED_USERS}}"

# --- Slack ---
SLACK_ENABLED="{{SLACK_ENABLED}}"
SLACK_BOT_TOKEN="{{SLACK_BOT_TOKEN}}"
SLACK_APP_TOKEN="{{SLACK_APP_TOKEN}}"
SLACK_ALLOWED_USERS="{{SLACK_ALLOWED_USERS}}"
SLACK_TEAM_ID="{{SLACK_TEAM_ID}}"

# --- Messaging ---
MESSAGING_CWD={{HERMES_HOME}}/workspace

# --- AI Providers ---
HERMES_GATEWAY_TOKEN="{{HERMES_GATEWAY_TOKEN}}"
HERMES_CODEX_BASE_URL="{{HERMES_CODEX_BASE_URL}}"
CODEX_AUTH_PROXY_URL="{{CODEX_AUTH_PROXY_URL}}"
# Optional: set if using OpenRouter, Anthropic, etc. as fallbacks
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=

# Customer-supplied OpenAI API key (pasted via the NoDesk portal). When set,
# the agent uses the `openai` image_gen plugin (gpt-image-2). Empty -> the
# agent falls back to `openai-codex` (ChatGPT subscription auth).
OPENAI_API_KEY="{{OPENAI_API_KEY}}"
IMAGE_GEN_PROVIDER="{{IMAGE_GEN_PROVIDER}}"

# --- ClickSend SMS ---
CLICKSEND_USERNAME="{{CLICKSEND_USERNAME}}"
CLICKSEND_API_KEY="{{CLICKSEND_API_KEY}}"
CLICKSEND_FROM="{{CLICKSEND_FROM_NUMBER}}"

# --- Facebook ---
FB_PAGE_ACCESS_TOKEN="{{FB_PAGE_ACCESS_TOKEN}}"
FACEBOOK_ACCESS_TOKEN="{{FACEBOOK_ACCESS_TOKEN}}"
FB_FORM_ID="{{FB_FORM_ID}}"

# --- Podio CRM ---
PODIO_CLIENT_ID="{{PODIO_CLIENT_ID}}"
PODIO_CLIENT_SECRET="{{PODIO_CLIENT_SECRET}}"
PODIO_APP_ID="{{PODIO_APP_ID}}"
PODIO_ACCESS_TOKEN="{{PODIO_ACCESS_TOKEN}}"
PODIO_REFRESH_TOKEN="{{PODIO_REFRESH_TOKEN}}"

# --- QuickBooks Online ---
QBO_ENVIRONMENT=production
QBO_CLIENT_ID="{{QBO_CLIENT_ID}}"
QBO_CLIENT_SECRET="{{QBO_CLIENT_SECRET}}"
QBO_REDIRECT_URI="{{QBO_REDIRECT_URI}}"
QBO_REALM_ID="{{QBO_REALM_ID}}"
QBO_ACCESS_TOKEN="{{QBO_ACCESS_TOKEN}}"
QBO_REFRESH_TOKEN="{{QBO_REFRESH_TOKEN}}"

# --- Jobber ---
JOBBER_CLIENT_ID="{{JOBBER_CLIENT_ID}}"
JOBBER_CLIENT_SECRET="{{JOBBER_CLIENT_SECRET}}"
JOBBER_ACCESS_TOKEN="{{JOBBER_ACCESS_TOKEN}}"
JOBBER_REFRESH_TOKEN="{{JOBBER_REFRESH_TOKEN}}"

# --- BoldTrail ---
BOLDTRAIL_API_TOKEN="{{BOLDTRAIL_API_TOKEN}}"
BOLDTRAIL_ACCESS_TOKEN="{{BOLDTRAIL_ACCESS_TOKEN}}"

# --- Clover POS ---
CLOVER_APP_ID="{{CLOVER_APP_ID}}"
CLOVER_APP_SECRET="{{CLOVER_APP_SECRET}}"
CLOVER_ACCESS_TOKEN="{{CLOVER_ACCESS_TOKEN}}"
CLOVER_REFRESH_TOKEN="{{CLOVER_REFRESH_TOKEN}}"
CLOVER_MERCHANT_ID="{{CLOVER_MERCHANT_ID}}"
CLOVER_SANDBOX="{{CLOVER_SANDBOX}}"

# NoDesk gateway URL — used by bootstrap.sh's bootstrap-complete callback
# and any other agent-initiated calls back into NoDesk.
NODESK_BASE_URL="{{NODESK_BASE_URL}}"

# --- GitHub (NoDesk App installation; token auto-refreshed by cron) ---
HERMES_CLIENT_ID="{{HERMES_CLIENT_ID}}"
GITHUB_INSTALLATION_ID="{{GITHUB_INSTALLATION_ID}}"
GITHUB_ACCOUNT_LOGIN="{{GITHUB_ACCOUNT_LOGIN}}"
GITHUB_TOKEN_ENDPOINT="{{GITHUB_TOKEN_ENDPOINT}}"
GITHUB_TOKEN="{{GITHUB_TOKEN}}"
GH_TOKEN="{{GH_TOKEN}}"

# --- Anti-detect browser ---
# The camofox-browser server runs locally on :9377 (systemd, installed by
# bootstrap.sh). With CAMOFOX_URL set, the agent's browser_* tools route to it
# (anti-detection Firefox) instead of headless Chrome. Hardcoded — not a
# {{VAR}} — because every agent runs the server. Remove to fall back to Chrome.
CAMOFOX_URL="http://localhost:9377"

# --- Business Context (used by bootstrap to render SOUL.md) ---
BUSINESS_NAME="{{BUSINESS_NAME}}"
OWNER_NAME="{{OWNER_NAME}}"
OWNER_PHONE="{{OWNER_PHONE}}"
ADMIN_NAME="{{ADMIN_NAME}}"
ADMIN_PHONE="{{ADMIN_PHONE}}"
AGENT_PERSONA_NAME="{{AGENT_PERSONA_NAME}}"
AGENT_SUBAGENT_NAME="{{AGENT_SUBAGENT_NAME}}"
